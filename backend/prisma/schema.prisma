datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Session {
  id            String   @id @default(uuid())
  sessionToken  String   @unique
  district      String?
  createdAt     DateTime @default(now())
  lastActive    DateTime @default(now())
  messages      Message[]
  wellbeing     Wellbeing[]
  consultations Consultation[]
  crisisEvents  CrisisEvent[]
}

model Message {
  id           String   @id @default(uuid())
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id])
  role         String   // "user" or "assistant"
  content      String
  emotionLabel String?
  createdAt    DateTime @default(now())
}

model Wellbeing {
  id          String   @id @default(uuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id])
  weekNumber  Int
  score       Float
  topics      String   // Stored as comma-separated or JSON string for SQLite
  createdAt   DateTime @default(now())
}

model Consultation {
  id         String   @id @default(uuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id])
  counselorId String?
  slotTime   DateTime?
  status     String   @default("pending")
  paymentRef String?
  createdAt  DateTime @default(now())
}

model CrisisEvent {
  id          String   @id @default(uuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id])
  triggerType String
  escalated   Boolean  @default(false)
  createdAt   DateTime @default(now())
}
